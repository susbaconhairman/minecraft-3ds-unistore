            "category":[
               "texture pack"
            ],
            "console":[
               "3DS"
            ],
            "description":"Port of the Kharrii2 Dirt/Grass Face pack by MegaMinerDL (v1.19.3)",
            "license":"none",
            "releasenotes": "This texture pack changes all of the dirt types to kharrii2's face.\n\nPorter - susbaconhairman\n\nCreator - MegaMinerDL\n\nCreated with permission of MegaMinerDL",
            "screenshots": [
               {
                  "description": "Textures show-off",
