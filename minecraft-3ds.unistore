               "required":false
            },
            {
               "type":"rmdir",
               "directory":"sdmc:/luma/titles/00040000001B8700/romfs/atlas",
               "required":false
            },
            {
               "type":"extractFile",
               "file":"sdmc:/Minecraft 3DS/kharrii2_textures.zip",
