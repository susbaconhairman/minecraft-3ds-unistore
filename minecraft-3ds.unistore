      {
         "info":{
            "title":"Remove Customization",
            "author":"susbaconhairman",
            "version":"4",
            "category":[
               "misc"
            ],
            "console":[
               "3DS"
            ],
            "description":"A tool for quickly and easily removing installed custom content from the game.",
            "license":"none",
            "releasenotes": "This is a tool for quickly and easily removing installed custom content from the game.\n\nWARNING: DELETED DATA IS NOT RECOVERABLE! YOU ARE RESPONSIBLE FOR ALL OF YOUR DATA AND WHAT YOU DO WITH IT!\n\n\nSelect options that match the correct region for your Minecraft 3DS game/console.\nFor instance, to remove all custom content from the game, select 'Remove ALL content (USA)'.\n\n\nRemove ALL content - Removes all installed custom content for the game, deletes the directory /luma/titles/(Minecraft 3DS Title ID) on your SD card.\n\nRemove textures - Removes all installed custom textures for the game, deletes the directories /luma/titles/(Minecraft 3DS Title ID)/romfs/resourcepacks/vanilla/client and sdmc:/luma/titles/(Minecraft 3DS Title ID)/romfs/atlas\n\nRemove skins - Removes all installed custom skins for the game, deletes the directory /luma/titles/(Minecraft 3DS Title ID)/romfs/resourcepacks/skins/skinpacks\n\nRemove mods - Removes all installed mods for the game, deletes the directory /luma/titles/(Minecraft 3DS Title ID)/romfs/resourcepacks/vanilla/server", 
            "screenshots": [
               {
                  "description": "No image is available. Sorry.",
                  "url": "https://github.com/bigskribbz/mc-3ds-unistore/raw/main/screenshots/stronghold-fix.png"
               }
            ],
            "icon_index":21,
            "sheet_index":0,
            "last_updated":"2023-02-19 at 15:55 (CST)"
         },
         "Remove ALL content (USA)":[
            {
               "type":"promptMessage",
               "message":"This will remove ALL installed\ncustom content for the game",
               "count":1
            },
            {
               "type":"rmdir",
               "directory":"sdmc:/luma/titles/00040000001B8700",
               "required":false
            }
         ],
         "Remove ALL content (EUR)":[
            {
               "type":"promptMessage",
               "message":"This will remove ALL installed\ncustom content for the game",
               "count":1
            },
            {
               "type":"rmdir",
               "directory":"sdmc:/luma/titles/000400000017CA00",
               "required":false
            }
         ],
